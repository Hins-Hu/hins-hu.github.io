---
layout: default
---
<div class="post">
  <article>

    <!-- Row 1: Name / Info / Icons (left) + Photo (right) -->
    <div class="row align-items-center mb-4">

      <div class="col-sm-8">
        <h1 class="post-title mb-1">
          {% if site.title == 'blank' %}
            <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
            {{ site.last_name }}
          {% else %}
            {{ site.title }}
          {% endif %}
        </h1>
        <p class="desc mb-2">{{ page.subtitle }}</p>

        {% if page.profile and page.profile.more_info %}
          <div class="more-info mb-3">{{ page.profile.more_info }}</div>
        {% endif %}

        {% if page.social %}
          <!-- Email line: icon + obfuscated address -->
          <div class="mb-2">
            <a href="mailto:{{ site.data.socials.email }}" style="color: inherit; font-size: 2rem; vertical-align: middle;">
              <i class="fas fa-envelope"></i>
            </a>
            <span style="font-size: 1rem; margin-left: 8px; vertical-align: middle;">
              zh223 [at] cornell [dot] edu
            </span>
          </div>
          <!-- Icons row: github + scholar + linkedin + Download CV -->
          <div class="d-flex align-items-center" style="gap: 12px;">
            <a href="https://github.com/{{ site.data.socials.github_username }}" target="_blank" style="color: inherit; font-size: 2rem;">
              <i class="fab fa-github"></i>
            </a>
            <a href="https://scholar.google.com/citations?user={{ site.data.socials.scholar_userid }}" target="_blank" style="color: inherit; font-size: 2rem;">
              <i class="ai ai-google-scholar"></i>
            </a>
            <a href="https://www.linkedin.com/in/{{ site.data.socials.linkedin_username }}" target="_blank" style="color: inherit; font-size: 2rem;">
              <i class="fab fa-linkedin"></i>
            </a>
            <a href="/assets/pdf/cv.pdf" class="btn btn-sm z-depth-0" role="button" target="_blank" style="font-size: 0.85rem; margin-left: -22px;">Download CV</a>
          </div>
        {% endif %}
      </div>

      <div class="col-sm-4 text-center">
        {% if page.profile and page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px) 30vw, 95vw"{% endcapture %}
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        {% endif %}
      </div>

    </div>

    <!-- Row 2: Bio (full width) -->
    <div class="row">
      <div class="col-12" style="text-align: justify;">
        {{ content }}
      </div>
    </div>

    <!-- Row 3: Research Interests (full width) -->
    {% if page.research_interests %}
      <div class="row mt-4">
        <div class="col-12">
          <h2>Research Interests</h2>
          <ul class="research-interests-list" style="text-align: justify;">
            {% for item in page.research_interests %}
              <li><strong>{{ item.area }}</strong> — {{ item.description }}</li>
            {% endfor %}
          </ul>
        </div>
      </div>
    {% endif %}

    <!-- Row 4: News (full width) -->
    {% if page.announcements and page.announcements.enabled %}
      <div class="row mt-4">
        <div class="col-12">
          <h2>
            <a href="{{ '/news/' | relative_url }}" style="color: inherit">News</a>
          </h2>
          {% include news.liquid limit=true %}
        </div>
      </div>
    {% endif %}

    <!-- Latest posts (full width) -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <div class="row mt-4">
        <div class="col-12">
          <h2>
            <a href="{{ '/blog/' | relative_url }}" style="color: inherit">Latest Posts</a>
          </h2>
          {% include latest_posts.liquid %}
        </div>
      </div>
    {% endif %}

    <!-- Selected papers (full width) -->
    {% if page.selected_papers %}
      <div class="row mt-4">
        <div class="col-12">
          <h2>
            <a href="{{ '/publications/' | relative_url }}" style="color: inherit">Selected Publications</a>
          </h2>
          {% include selected_papers.liquid %}
        </div>
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}

  </article>
</div>
